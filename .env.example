# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Daita — input daita api key to access cloud environment
# =============================================================================

DAITA_API_KEY=

# =============================================================================
# LLM Providers — set the key(s) for the provider(s) you use
# =============================================================================

# OpenAI (included by default)
OPENAI_API_KEY=

# Anthropic Claude (pip install "daita-agents[anthropic]")
ANTHROPIC_API_KEY=

# Google Gemini (pip install "daita-agents[google]")
GOOGLE_API_KEY=

# xAI Grok
XAI_API_KEY=

# =============================================================================
# Database Plugins (optional — only needed if using these plugins)
# =============================================================================

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# MySQL
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

# MongoDB
MONGODB_URI=

# =============================================================================
# Cloud & Integration Plugins (optional)
# =============================================================================

# AWS (S3, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Slack
SLACK_BOT_TOKEN=

# Tavily (web search plugin)
TAVILY_API_KEY=
